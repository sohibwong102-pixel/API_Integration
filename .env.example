# =====================================================================
# ⚙️ OPERATIONAL WORKFLOW API - ENVIRONMENT VARIABLES BLUEPRINT
# =====================================================================
# Salin berkas ini menjadi '.env' di direktori utama Anda:
#   $ cp .env.example .env
#
# PENTING: Jangan pernah melakukan commit berkas '.env' asli yang berisi 
# kredensial/kunci rahasia Anda ke repositori Git!
# =====================================================================

# 🖥️ 1. KONFIGURASI SERVER UTAMA
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

# 🤖 2. KONFIGURASI PENYEDIA AI (AI PROVIDER CONFIG)
# Pilihan Provider aktif: 'local_ollama', 'google_gemini', 'openrouter', atau 'mock'
AI_PROVIDER=local_ollama

# Opsional untuk provider mock:
# Summary fixture deterministik untuk testing/offline validation.
# Hanya dipakai jika AI_PROVIDER=mock atau FALLBACK_PROVIDER=mock.
MOCK_SUMMARY_FIXTURE=Mock summary for testing: operational issue detected and requires backend investigation.

# A. Konfigurasi AI Lokal (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# B. Konfigurasi Cloud AI (Google Gemini API)
# Dapatkan kunci API Anda di: https://aistudio.google.com/
GEMINI_API_KEY=your_google_gemini_api_key_here

# C. Konfigurasi Agregator AI Pihak Ketiga (OpenRouter)
# Dapatkan kunci API Anda di: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 💾 3. KONFIGURASI PENYIMPANAN DATA (DATABASE STORAGE)
# Path menuju file penyimpanan riwayat transaksi lokal
DB_STORAGE_PATH=storage/history.json
